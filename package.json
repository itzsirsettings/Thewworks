{
  "name": "thewworksict",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server-dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:api": "vitest run server/test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "security:audit": "npm audit --registry=https://registry.npmjs.org --audit-level=moderate",
    "security:audit:fix": "npm audit fix",
    "security:env:check": "npx tsx scripts/check-env.ts",
    "security:env:check:production": "npx tsx scripts/check-env.ts --production",
    "security:keys": "tsx scripts/generate-keys.ts",
    "security:supabase:check": "npx tsx scripts/check-supabase-readiness.ts",
    "prd:update": "tsx scripts/update-prd.ts",
    "prd:generate": "tsx scripts/generate-prd.ts"
  },
