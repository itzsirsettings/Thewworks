# ════════════════════════════════════════════════════════════════════════════
# THEWWORKS ICT E-COMMERCE APPLICATION - Environment Configuration
# ════════════════════════════════════════════════════════════════════
# This file contains all environment variables needed to run the application.
# Copy this file to .env and fill in the placeholder values.
#
# SECURITY WARNING: Never commit .env file to version control!
# Add .env to your .gitignore file.
# ════════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ════════════════════════════════════════════════════════════════════
# The port the Express server will listen on
SERVER_PORT=3001
# The public URL of your website (used for CORS, SEO canonical redirects, and payment callbacks)
# Local: http://localhost:5173
# Production Railway canonical origin: https://thewworksict.com
PUBLIC_SITE_URL=http://localhost:5173
# Additional allowed browser origins, comma-separated. Production: https://thewworksict.com
CORS_ALLOWED_ORIGINS=
# Node environment: development, production, test
NODE_ENV=development
# Maximum request body size (default: 5mb)
MAX_BODY_SIZE=5mb
# Service name for security logging
SECURITY_SERVICE_NAME=thewworksict-checkout-api

# ════════════════════════════════════════════════════════════════════
# PAYMENT PROCESSING (Paystack)
# ════════════════════════════════════════════════════════════════════
# Get your keys from: https://dashboard.paystack.com/#/api-settings
# Use sk_test locally and sk_live in production.
PAYSTACK_SECRET_KEY=sk_your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_your_paystack_public_key_here

# ════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ════════════════════════════════════════════════════════════════════
# Optional legacy direct Postgres connection string.
# The active app uses Supabase APIs; leave this unset unless using legacy direct-Postgres tooling.
# Use postgresql://user:pass@host:port/database when intentionally enabled.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/thewworks

# Database SSL mode: disable, require, verify-full
# Use 'require' or 'verify-full' for production Supabase connections
DATABASE_SSL_MODE=disable

# Database connection pool size (1-50)
DATABASE_POOL_MAX=10

# Statement timeout in milliseconds (optional, for query safety)
DATABASE_STATEMENT_TIMEOUT_MS=10000

# ════════════════════════════════════════════════════════════════════
# ENCRYPTION KEYS (CRITICAL - Keep secret!)
# ════════════════════════════════════════════════════════════════════
# Generate secure keys using: npm run security:keys
ORDER_STORE_ENCRYPTION_KEY=your_32_byte_base64_encoded_key_here
ORDER_TOKEN_SECRET=your_32_byte_base64_encoded_key_here

# CSRF Secret for signed double-submit browser tokens
# Note: CSRF_SECRET must be at least 32 characters and unique per environment
CSRF_SECRET=your_csrf_secret_key_here

# ════════════════════════════════════════════════════════════════════
# SUPABASE CONFIGURATION
# ════════════════════════════════════════════════════════════════════
# Get your keys from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ════════════════════════════════════════════════════════════════════
# ADMIN AUTHENTICATION
# ════════════════════════════════════════════════════════════════════
# Comma-separated list of admin email addresses authorized for dashboard
ADMIN_EMAILS=admin@example.com

# ════════════════════════════════════════════════════════════════════
# CAPTCHA (Cloudflare Turnstile)
# ════════════════════════════════════════════════════════════════════
# Get your keys from: https://dashboard.cloudflare.com/ (Turnstile section)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ════════════════════════════════════════════════════════════════════════════
# RATE LIMITING (Redis) - Optional but recommended for production
# ════════════════════════════════════════════════════════════════════
# Redis connection URL (use redis://localhost:6379 for local Redis)
# For production, use rediss:// for TLS: rediss://:password@redis.example.com:6380
REDIS_URL=redis://localhost:6379/0

# ════════════════════════════════════════════════════════════════════
# SECURITY ALERTS - Optional (Discord/Slack webhook for security events)
# ════════════════════════════════════════════════════════════════════
# Minimum severity to alert: info, warning, critical
SECURITY_ALERT_MIN_SEVERITY=warning
# Cooldown between alerts in milliseconds (default: 5 minutes)
SECURITY_ALERT_COOLDOWN_MS=300000
# Webhook URL for security alerts (e.g. Discord Webhook URL)
SECURITY_ALERT_WEBHOOK_URL=your_webhook_url_here
# Bearer token for webhook authentication (optional)
SECURITY_ALERT_BEARER_TOKEN=your_bearer_token_here

# ════════════════════════════════════════════════════════════════════
# EMAIL SERVICES (Resend) - For order confirmations
# ════════════════════════════════════════════════════════════════════
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
# From email address (must be a verified domain/email in Resend)
RESEND_FROM_EMAIL=orders@yourdomain.com

# ════════════════════════════════════════════════════════════════════
# SMS SERVICES (Twilio) - For order SMS notifications
# ════════════════════════════════════════════════════════════════════
# Get your credentials from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Your Twilio phone number (must be in E.164 format, e.g. +1234567890)
TWILIO_FROM_NUMBER=+1234567890

# ════════════════════════════════════════════════════════════════════
# STORE INFORMATION
# ════════════════════════════════════════════════════════════════════
STORE_NAME=Thewworks ICT
STORE_SUPPORT_EMAIL=support@yourdomain.com
STORE_SUPPORT_PHONE=+2348123986155

# ════════════════════════════════════════════════════════════════════
# VOICE SERVICES (ElevenLabs) - Optional feature
# ════════════════════════════════════════════════════════════════════
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here
